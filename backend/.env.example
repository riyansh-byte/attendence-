FLASK_APP=run.py
FLASK_ENV=development
PORT=5000

# Supabase Configurations
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-key-found-in-api-settings

# AWS S3 Settings
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=attendai-reports-storage

# n8n Webhook Configuration
N8N_ANOMALY_WEBHOOK_URL=https://n8n.workflow.myorg.com/webhook/attendance
N8N_SECRET_TOKEN=your-webhook-secret-token
